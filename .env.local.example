# Admin (comma-separated emails)
ADMIN_EMAILS=seb.grueber@gmail.com

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
