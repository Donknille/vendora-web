# ── Database: Neon Postgres ───────────────────────────────
# Pooled connection string from the Neon console (Connection Details → "Pooled").
# Keep ?sslmode=require. Used by both the app (Drizzle) and drizzle-kit.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Auth: Better Auth ─────────────────────────────────────
# Secret for signing sessions/tokens. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32+-char-random-secret
# Public base URL of the app (no trailing slash). Locally: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# ── Email: Resend (password reset + verification) ─────────
# Optional locally (emails are skipped with a warning if unset); required for
# password reset in production. Verify a domain in Resend for real recipients.
RESEND_API_KEY=re_...
EMAIL_FROM=Vendora <noreply@your-domain.de>

# ── Admin (comma-separated emails) ────────────────────────
ADMIN_EMAILS=seb.grueber@gmail.com

# ── Stripe (subscriptions) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Arcjet (rate limiting / security) ─────────────────────
# Optional locally; REQUIRED in production — without it the middleware fails closed
# and returns 503 for all requests (see src/proxy.ts).
ARCJET_KEY=ajkey_...
